# runtime writable data
runtime/archives/*
runtime/exports/*
runtime/exports/runs/*
runtime/logs/*
runtime/state/*

# keep skeleton only
!runtime/.gitkeep
!runtime/archives/.gitkeep
!runtime/exports/.gitkeep
!runtime/exports/runs/.gitkeep
!runtime/logs/.gitkeep
!runtime/state/.gitkeep

# packaging outputs
packaging/staging/
packaging/dist/
packaging/test_desktop/
packaging_backup/

# python cache
__pycache__/
*.pyc

# local patch/output
patched/

# local datasets
market_data/

# local venv
.venv/

# native launcher build outputs
launcher_native/bin/
launcher_native/obj/
setup_bootstrap/bin/
setup_bootstrap/obj/
