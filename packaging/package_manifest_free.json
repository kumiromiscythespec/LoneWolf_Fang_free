  ],
  "include_native_artifacts": [
    { "path": "LoneWolfFangFreeLauncher.exe", "source_candidates": ["LoneWolfFangFreeLauncher.exe", "launcher_native/bin/Release/net8.0-windows/publish/win-x64-single-file/LoneWolfFangFreeLauncher.exe"], "type": "file_if_present", "copy_mode": "file", "required": false, "group": "native_launcher", "role": "gui_entrypoint", "signing_scope": "package_root_only" },
    { "path": "LoneWolf_Fang_Free_Setup.exe", "source_candidates": ["LoneWolf_Fang_Free_Setup.exe", "setup_bootstrap/bin/Release/net8.0-windows/publish/win-x64-single-file/LoneWolf_Fang_Free_Setup.exe"], "type": "file_if_present", "copy_mode": "file", "required": false, "group": "native_setup_bootstrap", "role": "install_update_entrypoint", "signing_scope": "package_root_only" }
