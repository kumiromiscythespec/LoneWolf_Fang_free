  "include_advanced_tools": [],
  "runtime_skeleton": ["runtime", "runtime/archives", "runtime/exports", "runtime/exports/runs", "runtime/logs", "runtime/state", "configs/user"],
  "reinclude_after_exclude": ["runtime/.gitkeep", "runtime/archives/.gitkeep", "runtime/exports/.gitkeep", "runtime/exports/runs/.gitkeep", "runtime/logs/.gitkeep", "runtime/state/.gitkeep"],
  "exclude": [
    { "pattern": "runtime/archives/*", "reason": "runtime archives are writable outputs" },
    { "pattern": "runtime/exports/*", "reason": "runtime exports are writable outputs" },
    { "pattern": "runtime/exports/runs/*", "reason": "runtime run exports are writable outputs" },
    { "pattern": "runtime/logs/*", "reason": "runtime logs are writable outputs" },
    { "pattern": "runtime/state/*", "reason": "runtime state is writable output" },
    { "pattern": "market_data/*", "reason": "datasets are not bundled" },
    { "pattern": "patched/*", "reason": "patch artifacts are not bundled" },
    { "pattern": ".git/*", "reason": "git metadata is not bundled" },
    { "pattern": "*__pycache__*", "reason": "bytecode caches are not bundled" },
    { "pattern": "*.pyc", "reason": "bytecode caches are not bundled" },
    { "pattern": "packaging/staging/*", "reason": "staging outputs are not bundled" },
    { "pattern": "packaging/dist/*", "reason": "dist outputs are not bundled" }
  ],
  "notes": [
    "free uses shared base Python plus a product-specific venv under %LocalAppData%\\LoneWolfFang\\venvs\\free.",
    "launcher compatibility shims stay in the package root and the runtime data root is user-scope.",
    "native launcher and native setup bootstrap remain optional package artifacts.",
    "datasets are not bundled."
  ]
